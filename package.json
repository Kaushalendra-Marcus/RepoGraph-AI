{
  "name": "repograph-ai",
  "displayName": "RepoGraph AI",
  "description": "Visualize and understand any codebase instantly with AI-powered dependency graphs, file summaries, and codebase Q&A.",
  "version": "1.0.0",
  "publisher": "kaushalendra",
  "license": "MIT",

  "icon": "public/repograph-ai.png",

  "repository": {
    "type": "git",
    "url": "https://github.com/Kaushalendra-Marcus/CodeGraph-AI"
  },

  "engines": {
    "vscode": "^1.116.0"
  },

  "categories": [
    "AI",
    "Visualization"
  ],

  "keywords": [
    "ai",
    "code graph",
    "dependency graph",
    "code visualization",
    "codebase analysis",
    "developer tools"
  ],

  "main": "./out/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "repograph.open",
        "title": "RepoGraph AI: Open Panel",
        "icon": "$(graph)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repograph",
          "title": "RepoGraph AI",
          "icon": "public/assets/icon.svg"
        }
      ]
    },
    "views": {
      "repograph": [
        {
          "type": "webview",
          "id": "repograph.mainView",
          "name": "RepoGraph AI"
        }
      ]
    }
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },

  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.116.0",
    "typescript": "^5.9.3"
  }
}