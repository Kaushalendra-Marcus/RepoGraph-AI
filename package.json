{
  "name": "repograph-ai",
  "displayName": "RepoGraph AI",
  "description": "Understand any codebase instantly. Dependency graphs, AI file summaries, and codebase Q&A — fully local, bring your own key.",
  "version": "1.0.0",
  "publisher": "repograph",
  "license": "MIT",
  "icon": "assets/icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Other"],
  "keywords": ["ai", "codebase", "graph", "dependency", "analysis"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "repograph.open",
        "title": "RepoGraph AI: Open Panel",
        "icon": "$(graph)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repograph",
          "title": "RepoGraph AI",
          "icon": "assets/icon-mono.svg"
        }
      ]
    },
    "views": {
      "repograph": [
        {
          "type": "webview",
          "id": "repograph.mainView",
          "name": "RepoGraph AI",
          "icon": "assets/icon-mono.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.116.0",
    "typescript": "^5.9.3"
  }
}